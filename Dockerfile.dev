FROM node:20-slim

# Install prerequisites, add Adoptium repo, and install Java 21 JRE
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget \
    ca-certificates \
    gnupg \
    && wget -qO - https://packages.adoptium.net/artifactory/api/gpg/key/public | gpg --dearmor | tee /etc/apt/trusted.gpg.d/adoptium.gpg > /dev/null \
    && echo "deb https://packages.adoptium.net/artifactory/deb bookworm main" | tee /etc/apt/sources.list.d/adoptium.list \
    && apt-get update && apt-get install -y --no-install-recommends \
    temurin-21-jre \
    && rm -rf /var/lib/apt/lists/*

# Enable pnpm globally
RUN npm install -g pnpm

# Install firebase-tools globally so it's always available inside the containers
RUN npm install -g firebase-tools

WORKDIR /app

# Expose Next.js dev port
EXPOSE 3000

# By default, start Next.js development server
CMD ["pnpm", "dev"]
